# Copy to `.env.local` and fill in values. `.env.local` is gitignored.

# --- Supabase (Dashboard → Settings → API) ---
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Optional: your user UUID (Auth → Users). Only this user can use Admin → Manage editors.
# SUPER_USER_ID=

# Optional: deployed app URL for OAuth redirects (e.g. https://your-app.vercel.app)
# NEXT_PUBLIC_APP_URL=

# --- Cloudflare R2 (video / large file storage; server-only — never NEXT_PUBLIC_ or client bundle) ---
# See ENV_SETUP.md § Cloudflare R2 for where each value comes from.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=instant-sop-videos
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_REGION=auto

# Server-side video trim (ffmpeg). Off by default — needs ffmpeg, RAM, and time for large files.
# NEXT_PUBLIC_ENABLE_VIDEO_CUT=true
# On Vercel: use async jobs + waitUntil for long cuts (requires video_processing_jobs table in DB).
# NEXT_PUBLIC_VIDEO_CUT_ASYNC=true
